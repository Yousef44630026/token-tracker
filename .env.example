# Reference environment variables — NEVER commit a real key.
# Export these variables in the process environment (or use your service/secret manager).
# The tracker deliberately does not auto-load .env files.

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- Azure / Azure AI Foundry ---
AZURE_OPENAI_API_KEY=...

# Azure OpenAI classic deployment routes: chat + embeddings.
AZURE_OPENAI_ENDPOINT=https://mon-ressource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=mon-deploiement-chat
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=mon-deploiement-embeddings
AZURE_OPENAI_API_VERSION=2024-10-21

# Azure AI Foundry / OpenAI v1 Responses route.
AZURE_OPENAI_RESPONSES_ENDPOINT=https://mon-projet.services.ai.azure.com/openai/v1
AZURE_OPENAI_RESPONSES_DEPLOYMENT=mon-deploiement-responses

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Google Gemini (Developer API) ---
GEMINI_API_KEY=...
# ou GOOGLE_API_KEY=...

# --- Google Vertex AI ---
GOOGLE_CLOUD_PROJECT=mon-projet-gcp
GOOGLE_CLOUD_LOCATION=us-central1

# --- Mistral ---
MISTRAL_API_KEY=...

# --- Token tracker collector ---
# Keep the append-only ledger outside OneDrive/Dropbox/Google Drive.
TRACKER_STORE=C:\ai-token-tracker-data\collector_events.jsonl
TRACKER_HOST=127.0.0.1
TRACKER_PORT=8787
TRACKER_DURABLE=true
# Optional high-volume mode: TRACKER_STORE is then a directory partitioned by date/trace.
TRACKER_PARTITIONED=false
# Set for bearer authentication; keep secret.
TRACKER_AUTH_TOKEN=...

# --- Scheduled Excel dashboard ---
TRACKER_DASHBOARD_DATA_DIR=C:\ai-token-tracker-data
TRACKER_DASHBOARD_OUTPUT=C:\ai-token-tracker-data\dashboard.xlsx
# Optional external effective-dated price table. Leave unset when prices are unknown.
# TRACKER_DASHBOARD_PRICES=C:\ai-token-tracker-data\prices.csv
TRACKER_DASHBOARD_EVIDENCE=C:\ai-token-tracker-data\health\dashboard-refresh.json
TRACKER_DASHBOARD_STALE_SECONDS=7200

# --- Real-call comparison proxy ---
# Loopback only. The proxy forwards credentials in memory but never stores them.
TRACKER_PROXY_HOST=127.0.0.1
TRACKER_PROXY_PORT=8080
TRACKER_PROXY_STORE=C:\ai-token-tracker-data\proxy_events.jsonl
TRACKER_PROXY_DURABLE=true
