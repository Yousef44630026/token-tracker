# Copiez ce fichier en .env (ou exportez ces variables) — NE JAMAIS committer de vraie cle.
# Le tracker ne lit aucune cle en dur : tout passe par l'environnement.

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- Azure / Azure AI Foundry ---
AZURE_OPENAI_API_KEY=...

# Azure OpenAI classic deployment routes: chat + embeddings.
AZURE_OPENAI_ENDPOINT=https://mon-ressource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=mon-deploiement-chat
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=mon-deploiement-embeddings
AZURE_OPENAI_API_VERSION=2024-10-21

# Azure AI Foundry / OpenAI v1 Responses route.
AZURE_OPENAI_RESPONSES_ENDPOINT=https://mon-projet.services.ai.azure.com/openai/v1
AZURE_OPENAI_RESPONSES_DEPLOYMENT=mon-deploiement-responses

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Google Gemini (Developer API) ---
GEMINI_API_KEY=...
# ou GOOGLE_API_KEY=...

# --- Google Vertex AI ---
GOOGLE_CLOUD_PROJECT=mon-projet-gcp
GOOGLE_CLOUD_LOCATION=us-central1

# --- Mistral ---
MISTRAL_API_KEY=...

# --- Token tracker collector ---
TRACKER_STORE=collector_events.jsonl
TRACKER_HOST=127.0.0.1
TRACKER_PORT=8787
TRACKER_DURABLE=false
# Set for bearer authentication; keep secret.
TRACKER_AUTH_TOKEN=...

# --- Real-call comparison proxy ---
# Loopback only. The proxy forwards credentials in memory but never stores them.
TRACKER_PROXY_HOST=127.0.0.1
TRACKER_PROXY_PORT=8080
TRACKER_PROXY_STORE=real_call_events.jsonl
